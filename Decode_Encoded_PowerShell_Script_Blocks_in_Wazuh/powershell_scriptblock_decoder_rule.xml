<group name="windows,powershell,scriptblock,alistoir_decoder,">

  <rule id="110420" level="8">
    <if_sid>91809</if_sid>
    <field name="win.system.eventID">4104</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(-enc|-encodedcommand|frombase64string|[A-Za-z0-9+/=]{80,})</field>
    <description>PowerShell ScriptBlock contains encoded or obfuscated content for decoder enrichment.</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
    <group>powershell,scriptblock,encoded_content,custom_rule,</group>
  </rule>

</group>

<group name="powershell_decoder,enrichment,alistoir_decoder,">

  <rule id="110430" level="0">
    <decoded_as>json</decoded_as>
    <field name="integration">^powershell_decoder$</field>
    <description>Decoded PowerShell enrichment record generated by custom decoder integration.</description>
    <group>powershell_decoder,enrichment,custom_rule,</group>
  </rule>

  <rule id="110431" level="7">
    <if_sid>110430</if_sid>
    <field name="risk">^high$</field>
    <description>Decoded PowerShell script on $(agent_name) contains multiple suspicious indicators and merits review.</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
    <group>powershell_decoder,high_risk,custom_rule,</group>
  </rule>

  <rule id="110432" level="12">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(iex|invoke-expression|&\s*\(\s*new-object\s+net\.webclient\)|\|\s*iex).*(downloadstring|downloadfile|invoke-webrequest|invoke-restmethod|new-object\s+net\.webclient)</field>
    <description>Decoded PowerShell downloads remote content and executes it in memory on $(agent_name).</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1105</id>
    </mitre>
    <group>powershell_decoder,download_execute,custom_rule,</group>
  </rule>

  <rule id="110433" level="14">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(add-mppreference|set-mppreference|remove-mppreference|disableantispyware|disablerealtimemonitoring|disableioavprotection|disablebehaviormonitoring|exclusionpath|exclusionprocess|exclusionextension|threatiddefaultaction_actions|mpcmdrun)</field>
    <description>Decoded PowerShell attempts to disable or weaken Microsoft Defender protections on $(agent_name).</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>powershell_decoder,defense_evasion,custom_rule,</group>
  </rule>

  <rule id="110434" level="13">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(amsiutils|amsiscanbuffer|amsiinitfailed|system\.management\.automation\.amsiutils|getfield\(\s*['\"]amsiinitfailed['\"]|setvalue\(\s*\$null\s*,\s*\$true\s*\)|\[ref\]\.assembly\.gettype\(\s*['\"]system\.management\.automation\.amsiutils['\"]|amsi.*bypass)</field>
    <description>Decoded PowerShell contains a likely AMSI bypass technique on $(agent_name).</description>
    <mitre>
      <id>T1562.001</id>
      <id>T1027</id>
    </mitre>
    <group>powershell_decoder,amsi_bypass,custom_rule,</group>
  </rule>

  <rule id="110435" level="5">
    <if_sid>110430</if_sid>
    <field name="iocs.urls" type="pcre2">https?://</field>
    <description>Decoded PowerShell on $(agent_name) contains one or more URLs for analyst context.</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>powershell_decoder,ioc,url,custom_rule,</group>
  </rule>

  <rule id="110436" level="12">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(invoke-webrequest|invoke-restmethod|downloadfile|start-bitstransfer|bitsadmin|certutil|new-object\s+net\.webclient).*(start-process|invoke-item|rundll32|regsvr32|mshta|cmd\.exe\s*/c|powershell\.exe)</field>
    <description>Decoded PowerShell downloads a payload and launches a follow-on process on $(agent_name).</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1105</id>
      <id>T1204</id>
    </mitre>
    <group>powershell_decoder,download_execute,process_launch,custom_rule,</group>
  </rule>

  <rule id="110437" level="12">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(new-object\s+net\.webclient|invoke-webrequest|invoke-restmethod|start-bitstransfer|bitsadmin|certutil).*(\$env:temp|appdata|programdata|public\\|users\\public|temp\\).*(\.exe|\.dll|\.ps1|\.bat|\.cmd|\.hta|\.sct)</field>
    <description>Decoded PowerShell stages a downloaded payload into a common writable path on $(agent_name).</description>
    <mitre>
      <id>T1105</id>
      <id>T1036</id>
    </mitre>
    <group>powershell_decoder,payload_staging,custom_rule,</group>
  </rule>

  <rule id="110438" level="6">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(-windowstyle\s+hidden|-w\s+hidden|-nop\b|-noni\b|-executionpolicy\s+bypass)</field>
    <description>Decoded PowerShell on $(agent_name) uses stealthy launcher arguments that may warrant correlation.</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
    <group>powershell_decoder,stealth_launcher,custom_rule,</group>
  </rule>

  <rule id="110439" level="14">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(?=.*(?:iex|invoke-expression|\|\s*iex))(?=.*(?:new-object\s+net\.webclient|net\.webclient|downloadstring|downloaddata))</field>
    <description>Decoded PowerShell on $(agent_name) combines Invoke-Expression with WebClient-style remote content retrieval.</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1105</id>
    </mitre>
    <group>powershell_decoder,download_execute,webclient_iex,custom_rule,</group>
  </rule>

  <rule id="110440" level="13">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)(start-bitstransfer|bitsadmin(?:\.exe)?\s+/(?:transfer|addfile|create|resume)).*(https?://|ftp://|\\\\|\.)(.*(\.exe|\.dll|\.ps1|\.hta|\.bat|\.cmd|start-process|invoke-item|powershell\.exe|cmd\.exe\s*/c))?</field>
    <description>Decoded PowerShell on $(agent_name) uses BITS or bitsadmin to fetch or stage a payload.</description>
    <mitre>
      <id>T1197</id>
      <id>T1105</id>
    </mitre>
    <group>powershell_decoder,bits_transfer,custom_rule,</group>
  </rule>

  <rule id="110441" level="13">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)certutil(?:\.exe)?.*(-urlcache|-verifyctl|-decode|-decodehex|-split|-f).*(https?://|ftp://|\.cer\b|\.crt\b|\.exe\b|\.dll\b|\.ps1\b|\.bat\b|\.cmd\b)</field>
    <description>Decoded PowerShell on $(agent_name) leverages certutil for remote retrieval or payload transformation.</description>
    <mitre>
      <id>T1105</id>
      <id>T1140</id>
    </mitre>
    <group>powershell_decoder,certutil,custom_rule,</group>
  </rule>

  <rule id="110442" level="14">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)mshta(?:\.exe)?.*(https?://|javascript:|vbscript:|about:|\.hta\b)</field>
    <description>Decoded PowerShell on $(agent_name) launches mshta with remote or scriptable content.</description>
    <mitre>
      <id>T1218.005</id>
    </mitre>
    <group>powershell_decoder,mshta,custom_rule,</group>
  </rule>

  <rule id="110443" level="13">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)rundll32(?:\.exe)?.*(https?://|javascript:|appdata|programdata|users\\public|public\\|temp\\|\.dll\b.*,)</field>
    <description>Decoded PowerShell on $(agent_name) launches rundll32 with a suspicious DLL path or remote content reference.</description>
    <mitre>
      <id>T1218.011</id>
    </mitre>
    <group>powershell_decoder,rundll32,custom_rule,</group>
  </rule>

  <rule id="110444" level="14">
    <if_sid>110430</if_sid>
    <field name="decoded_script" type="pcre2">(?i)regsvr32(?:\.exe)?.*(scrobj\.dll|/i:https?://|https?://.*\.sct\b|/s\s+/n\s+/u|appdata|programdata|users\\public|public\\|temp\\|\.dll\b)</field>
    <description>Decoded PowerShell on $(agent_name) launches regsvr32 in a pattern associated with remote scriptlet or suspicious DLL execution.</description>
    <mitre>
      <id>T1218.010</id>
    </mitre>
    <group>powershell_decoder,regsvr32,custom_rule,</group>
  </rule>

</group>
