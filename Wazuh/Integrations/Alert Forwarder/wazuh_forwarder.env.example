TRACKIR_SOAR_URL=https://<YOUR_ALISTOIR_SERVER_IP_OR_DOMAIN>/alerts/ingest.php
# Global Ingest API Key
TRACKIR_SOAR_API_KEY=<GLOBAL_API_KEY>
# Tenant key generated from Tenant Settings > Ingestion API Keys.
# Required when AlistoIR enforces tenant-scoped ingestion. SET_TENANT_KEY_RAW_VALUE_HERE
TRACKIR_TENANT_KEY=<ali_TENANT_KEY>
# Optional fallback/source label. For manager-bound keys, set this to the same
# value as the Wazuh payload manager.name / TrackIR manager_key.
# TRACKIR_WAZUH_SOURCE=<WAZUH_MANAGER_NAME>
TRACKIR_WAZUH_ALERTS_FILE=/var/ossec/logs/alerts/alerts.json
TRACKIR_STATE_DB=/var/ossec/integrations/soar_forwarder_state.db
TRACKIR_LOG_FILE=/var/ossec/logs/integrations/soar_forwarder.log
# Forward alerts at or above this Wazuh rule level (e.g. 11 = high+critical)
TRACKIR_MIN_LEVEL=3 
# Optional: always forward these specific rule IDs even if below MIN_LEVEL.
# Works alongside MIN_LEVEL — both filters are active at the same time (OR logic).
# Example: TRACKIR_RULE_IDS=100300,100301,100302,5710
# TRACKIR_RULE_IDS=651
TRACKIR_CHECK_INTERVAL=2
TRACKIR_REQUEST_TIMEOUT=60
TRACKIR_MAX_RETRIES=5
TRACKIR_FORWARD_DELAY=0.2
TRACKIR_PROCESSED_RETENTION_DAYS=14
TRACKIR_DISABLE_PROCESSED_STATE=0
TRACKIR_DEBUG_ALERTS=0
TRACKIR_START_AT_END_ON_FRESH_RUN=1
TRACKIR_RESET_CURSOR_ON_START=0
TRACKIR_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
